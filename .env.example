# DolphinPhoto AI Studio - Environment Configuration

# Server Configuration
HOST=127.0.0.1
PORT=7777
DEBUG=false

# Device Configuration
# Options: cuda, mps, cpu
DEVICE=cpu

# API Keys (Optional)
CIVITAI_API_KEY=
HF_TOKEN=

# Model Settings
DEFAULT_MODEL=stabilityai/stable-diffusion-2-1
SAFETY_CHECKER=true
ATTENTION_SLICE=true
VAE_SLICE=true

# Workspace
WORKSPACE_DIR=~/.dolphinphoto
